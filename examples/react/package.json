{
  "name": "one-system-cas-react-example",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Minimal Vite + React sample for @cas-system/react-cas-client (CasProvider + useCasAuth/useCasUser + CasLoginButton + CasProtectedRoute), with a tiny Express backend that performs the server-to-server /api/validate-token call.",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "cross-env API_PORT=9108 vite",
    "dev:api": "cross-env PORT=9108 node server.js",
    "build": "vite build",
    "start": "node server.js"
  },
  "dependencies": {
    "@cas-system/react-cas-client": "file:../../packages/react-cas-client",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.18.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "typescript": "^5.6.3",
    "vite": "^6.0.7"
  }
}
